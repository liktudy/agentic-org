{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agentic-org Company Spec",
  "type": "object",
  "required": [
    "id",
    "name",
    "display_name",
    "domain",
    "task_level",
    "status",
    "created_by",
    "creation_reason",
    "departments",
    "minimum_structure",
    "second_perspective",
    "workflows",
    "artifacts",
    "lifecycle",
    "performance"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "#/$defs/company_id"
    },
    "name": {
      "$ref": "#/$defs/company_id"
    },
    "display_name": {
      "$ref": "#/$defs/non_empty_string"
    },
    "domain": {
      "$ref": "#/$defs/non_empty_string"
    },
    "task_level": {
      "type": "string",
      "enum": ["L1", "L2", "L3"]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "under_review",
        "merge_candidate",
        "closure_candidate",
        "closed"
      ]
    },
    "created_by": {
      "type": "string",
      "enum": ["headquarters"]
    },
    "creation_reason": {
      "$ref": "#/$defs/non_empty_string"
    },
    "reuse_decision": {
      "type": "object",
      "required": ["checked_existing_companies", "decision", "reason"],
      "additionalProperties": false,
      "properties": {
        "checked_existing_companies": {
          "type": "boolean"
        },
        "decision": {
          "type": "string",
          "enum": [
            "created_as_first_company",
            "reuse_existing",
            "extend_existing",
            "create_new",
            "merge_candidate",
            "uncertain_escalated"
          ]
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "departments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "display_name", "agents"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/$defs/kebab_id"
          },
          "display_name": {
            "$ref": "#/$defs/non_empty_string"
          },
          "agents": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/kebab_id"
            }
          }
        }
      }
    },
    "minimum_structure": {
      "type": "object",
      "required": [
        "has_orchestration",
        "has_planning",
        "has_execution",
        "has_review",
        "omitted_by_highest_leader"
      ],
      "additionalProperties": false,
      "properties": {
        "has_orchestration": {
          "type": "boolean"
        },
        "has_planning": {
          "type": "boolean"
        },
        "has_execution": {
          "type": "boolean"
        },
        "has_review": {
          "type": "boolean"
        },
        "omitted_by_highest_leader": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/kebab_id"
          }
        }
      }
    },
    "second_perspective": {
      "type": "object",
      "required": ["required", "reason", "agents"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "agents": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/kebab_id"
          }
        }
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^companies/company-[a-z0-9]+(?:-[a-z0-9]+)*/WORKFLOW\\.md$"
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["internal", "external"],
      "additionalProperties": false,
      "properties": {
        "internal": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [".md", ".csv", ".json"]
          }
        },
        "external": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["pptx", "docx", "pdf", "html", "md", "csv", "json"]
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["last_review_at", "review_reason", "closure_requires_approval"],
      "additionalProperties": false,
      "properties": {
        "last_review_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "review_reason": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "closure_requires_approval": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "performance": {
      "type": "object",
      "required": [
        "execution_count",
        "success_count",
        "failure_count",
        "review_failure_count",
        "reuse_count",
        "delivery_count",
        "overlap_warnings",
        "last_execution_at",
        "last_success_at"
      ],
      "additionalProperties": false,
      "properties": {
        "execution_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "success_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "failure_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "review_failure_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "reuse_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "delivery_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "overlap_warnings": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "last_execution_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "last_success_at": {
          "$ref": "#/$defs/nullable_date_time"
        }
      }
    },
    "governance_notes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    }
  },
  "$defs": {
    "company_id": {
      "type": "string",
      "pattern": "^company-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "kebab_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "nullable_date_time": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
