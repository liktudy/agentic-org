{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agentic-org Workflow State",
  "type": "object",
  "required": ["task_id", "company", "current_stage", "status", "owner", "updated_at"],
  "properties": {
    "task_id": { "type": "string" },
    "company": { "type": "string" },
    "current_stage": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "in_progress", "reviewing", "revision_required", "escalated", "approved", "completed", "abandoned"]
    },
    "owner": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "review_count": {
      "type": "integer",
      "minimum": 0
    },
    "escalation_required": { "type": "boolean" },
    "highest_leader_decision": {
      "type": ["string", "null"]
    },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
